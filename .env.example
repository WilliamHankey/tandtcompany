# Sanity (create project at https://www.sanity.io/manage)
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-05-22

# Sanity Studio (same project — used in /sanity folder)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOSTNAME=tandtcompany

# Seed script (write token from sanity.io/manage → API → Tokens)
SANITY_API_TOKEN=your_write_token

# Paystack (https://dashboard.paystack.com)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
